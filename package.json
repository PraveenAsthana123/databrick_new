{
  "name": "databrick_new",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "better-sqlite3": "^12.9.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json,md}\"",
    "validate": "npm run lint && npm run format:check && npm test -- --watchAll=false",
    "pre-merge": "npm run validate && npm run build",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "prompt:save": "node scripts/prompt-tracker.js --save",
    "prompt:list": "node scripts/prompt-tracker.js --list",
    "prompt:search": "node scripts/prompt-tracker.js --search",
    "prompt:export": "node scripts/prompt-tracker.js --export",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "warn",
      "no-console": "warn",
      "no-unused-vars": "warn",
      "react/jsx-no-duplicate-props": "error",
      "react/no-direct-mutation-state": "error",
      "react/jsx-key": "error",
      "no-var": "error",
      "prefer-const": "warn",
      "eqeqeq": [
        "error",
        "always"
      ],
      "no-eval": "error",
      "no-implied-eval": "error",
      "no-useless-escape": "off"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "npx prettier --write",
      "npx eslint --fix --max-warnings=0"
    ],
    "src/**/*.{css,json,md}": [
      "npx prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sonarqube-scanner": "^4.3.6"
  }
}
